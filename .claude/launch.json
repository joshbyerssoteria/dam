{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "demo-church",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "NEXT_PUBLIC_ORG_NAME=Grace Fellowship",
        "NEXT_PUBLIC_ORG_FULL_NAME=Grace Fellowship Church",
        "NEXT_PUBLIC_APP_NAME=Grace Assets",
        "NEXT_PUBLIC_ORG_CONTACT_TEAM=Grace media team",
