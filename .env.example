# Organization (white-label identity — read by lib/config.ts).
# All optional: defaults are Soteria's. Run `npm run setup` to fill these in.
NEXT_PUBLIC_ORG_NAME=
NEXT_PUBLIC_ORG_FULL_NAME=
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_ORG_CONTACT_TEAM=
NEXT_PUBLIC_LOGIN_EMAIL_PLACEHOLDER=
NEXT_PUBLIC_ORG_LOGO_PATH=
# IANA timezone for the home-page greeting; blank = America/Chicago.
NEXT_PUBLIC_ORG_TIMEZONE=
# "off" hides the built-in Brand Guide (it is Soteria's brand content).
NEXT_PUBLIC_BRAND_GUIDE=
# Comma-separated AI tagging event types; blank = default church taxonomy.
NEXT_PUBLIC_EVENT_TYPES=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email
RESEND_API_KEY=

# Background jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Stable per deployment; changing it orphans the registered Inngest app.
INNGEST_APP_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
